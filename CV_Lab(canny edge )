estamp":1774335804023,"user_tz":-330,"elapsed":4,"user":{"displayName":"Atharva","userId":"08799971487908463692"}}},"execution_count":31,"outputs":[]},{"cell_type":"markdown","source":[],"metadata":{"id":"En-NPNbJoDq7"}},{"cell_type":"code","source":["import numpy as np\n","\n","def non_max_suppression(magnitude, angle):\n","  H, W = magnitude.shape\n","  Z = np.zeros((H, W), dtype=np.float32)\n","\n","  #convert angle from radians to degree\n","\n","  angle = angle* 180. / np.pi\n","  angle[angle < 0] += 180\n","\n","  for i in range(1, H-1):\n","    for j in range(1, W-1):\n","      q  = 255\n","      r = 255\n","\n","      # 0 degrees (horizontal edge)\n","      if (0 <= angle[i, j] < 22.5) or (157.5 <= angle[i, j] <= 1):\n","        q = magnitude[i, j+1]\n","        r = magnitude[i, j-1]\n","\n","      # 45 degrees (diagonal edge)\n","      elif (22.5 <= angle[i, j] < 67):\n","        q = magnitude[i+1, j-1]\n","        r = magnitude[i-1, j+1]\n","\n","      # 90 degrees (vertical edge)\n","      elif (67 <= angle[i, j] < 112.5):\n","        q = magnitude[i+1, j]\n","        r = magnitude[i-1, j]\n","\n","      #135 degrees\n","      elif (112.5 <= angle[i, j] <157.5):\n","        q = magnitude[i-1, j-1]\n","        r = magnitude[i+1, j+1]\n","\n","\n","     #Suppression Condition\n","      if (magnitude[i, j] >= q) and (magnitude[i, j] >= r):\n","        Z[i, j] = magnitude[i, j]\n","      else:\n","        Z[i, j] = 0\n","\n","  return Z\n",""],"metadata":{"id":"YXiR9_DdnqJX","executionInfo":{"status":"ok","timestamp":1774335806196,"user_tz":-330,"elapsed":1,"user":{"displayName":"Atharva","userId":"08799971487908463692"}}},"execution_count":32,"outputs":[]},{"cell_type":"code","source":["#step 3 APPLY NMS\n","\n","nms_output = non_max_suppression(magnitude, angle)\n","cv2_imshow(nms_output)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":209},"id":"cN1wX9fDnBby","executionInfo":{"status":"ok","timestamp":1774335808611,"user_tz":-330,"elap